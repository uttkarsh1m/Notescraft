generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  notes       Note[]       @relation("NoteOwner")
  sharedNotes NoteShare[]  @relation("SharedWithUser")

  @@map("users")
}

model Note {
  id        String    @id @default(uuid())
  title     String
  content   String
  isPinned  Boolean   @default(false) @map("is_pinned")
  isDeleted Boolean   @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  ownerId String @map("owner_id")
  owner   User   @relation("NoteOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  tags   NoteTag[]
  shares NoteShare[]

  @@map("notes")
}

model Tag {
  id    String    @id @default(uuid())
  name  String    @unique
  notes NoteTag[]

  @@map("tags")
}

model NoteTag {
  noteId String @map("note_id")
  tagId  String @map("tag_id")

  note Note @relation(fields: [noteId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([noteId, tagId])
  @@map("note_tags")
}

model NoteShare {
  id         String   @id @default(uuid())
  noteId     String   @map("note_id")
  sharedWith String   @map("shared_with")
  createdAt  DateTime @default(now()) @map("created_at")

  note User @relation("SharedWithUser", fields: [sharedWith], references: [id], onDelete: Cascade)
  Note Note @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@unique([noteId, sharedWith])
  @@map("note_shares")
}
